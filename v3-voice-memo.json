    {
      "parameters": {
        "jsCode": "// Transcribe（文字起こし）と Summarize（要約JSON）の出力から、保存用の行データを組み立てる。\n// Gemini ノードの出力はテキストが content.parts[0].text に入る形なので、そこから取り出す。\nconst transcript = $('Transcribe Audio').item.json.content?.parts?.[0]?.text\n  ?? $('Transcribe Audio').item.json.text ?? '';\n\nlet raw = $json.content?.parts?.[0]?.text ?? $json.text ?? '';\nif (typeof raw !== 'string') raw = JSON.stringify(raw);\nraw = raw.replaceAll('```json', '').replaceAll('```', '').trim();\n\nlet summary = '';\nlet tasks = '';\ntry {\n  const j = JSON.parse(raw);\n  summary = j.summary || '';\n  tasks = Array.isArray(j.tasks) ? j.tasks.join('\\n') : (j.tasks || '');\n} catch (e) {\n  // JSON でなければ、返ってきたテキストをそのまま要約として保存\n  summary = raw;\n}\n\nreturn {\n  recorded_at: new Date().toISOString(),\n  summary,\n  tasks,\n  transcript,\n};"
      },
